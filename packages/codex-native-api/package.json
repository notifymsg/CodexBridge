{
  "name": "@codexbridge/codex-native-api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Localhost API facade over the logged-in Codex app-server runtime.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "engines": {
    "node": ">=24"
  }
}
